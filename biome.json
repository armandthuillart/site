{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"assist": {
		"actions": {
			"source": {
				"noDuplicateClasses": "on",
				"organizeImports": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on",
				"useSortedProperties": "on"
			}
		},
		"enabled": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"formatter": {
			"enabled": true
		}
	},
	"json": {
		"formatter": {
			"expand": "always"
		}
	},
	"linter": {
		"rules": {
			"a11y": "on",
			"complexity": "on",
			"correctness": "on",
			"nursery": "on",
			"performance": "on",
			"security": "on",
			"style": "on",
			"suspicious": "on"
		}
	},
	"overrides": [
		{
			"includes": [
				"**"
			],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveLinesPerFunction": "off"
					},
					"correctness": {
						"noUndeclaredVariables": "off",
						"noUnresolvedImports": "off",
						"useJsxKeyInIterable": "off",
						"useQwikValidLexicalScope": "off"
					},
					"nursery": {
						"noLeakedRender": "off",
						"noShadow": "off",
						"noUnknownAttribute": "off",
						"useExplicitType": "off",
						"useSortedClasses": "off"
					},
					"performance": {
						"useSolidForComponent": "off"
					},
					"style": {
						"noDefaultExport": "off",
						"noImplicitBoolean": "off",
						"noJsxLiterals": "off",
						"noRestrictedGlobals": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/*.astro"
			],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"style": {
						"useExportsLast": "off",
						"useImportType": "off"
					}
				}
			}
		}
	],
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
