{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"assist": {
		"actions": {
			"source": { "useSortedKeys": "on" }
		},
		"enabled": true
	},
	"css": {
		"parser": { "tailwindDirectives": true }
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"formatter": { "enabled": true }
	},
	"json": {
		"formatter": { "expand": "auto" }
	},
	"linter": {
		"domains": { "project": "recommended" }
	},
	"overrides": [
		{
			"assist": {
				"actions": {
					"source": { "organizeImports": "off", "useSortedKeys": "off" }
				}
			},
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"style": { "useImportType": "off" }
				}
			}
		}
	],
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
