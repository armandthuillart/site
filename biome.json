{
	"$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
	"assist": {
		"actions": {
			"source": {
				"recommended": true,
				"useSortedAttributes": "on",
				"useSortedKeys": "on",
				"useSortedProperties": "on"
			}
		},
		"enabled": true
	},
	"css": {
		"parser": { "tailwindDirectives": true }
	},
	"files": {
		"includes": ["**/*.{ts,tsx}", "**/*.{json,jsonc}", "!**/*.gen.ts"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"domains": {
			"project": "all",
			"react": "all"
		},
		"enabled": true,
		"rules": {
			"a11y": "on",
			"complexity": "on",
			"correctness": "on",
			"nursery": "on",
			"performance": "on",
			"security": "on",
			"style": "on",
			"suspicious": "on"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.ts", "**/*.tsx"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveLinesPerFunction": {
							"level": "on",
							"options": { "maxLines": 100 }
						}
					},
					"nursery": {
						"noJsxLiterals": "off",
						"noJsxPropsBind": "off",
						"noUnresolvedImports": "off",
						"useAwaitThenable": "off",
						"useExplicitType": "off",
						"useQwikValidLexicalScope": "off",
						"useSortedClasses": {
							"fix": "safe",
							"level": "on",
							"options": {
								"attributes": ["classList"],
								"functions": ["cn", "cva", "tw"]
							}
						}
					},
					"performance": {
						"useSolidForComponent": "off"
					},
					"security": {
						"noSecrets": "off"
					},
					"style": {
						"noHeadElement": "off",
						"useComponentExportOnlyModules": "off",
						"useFilenamingConvention": "off",
						"useNamingConvention": "off"
					},
					"suspicious": {
						"noReactSpecificProps": "off"
					}
				}
			}
		},
		{
			"includes": ["*.config.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		}
	],
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
