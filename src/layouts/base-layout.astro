---
import BaseHead from "@components/base-head.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<html lang="en" class="antialiased scheme-light-dark">
  <head>
    <BaseHead title={title} />
  </head>

  <body class="bg-background text-foreground selection:bg-selection">
    <main class="overflow-clip isolate">
      <div class="px-6 md:px-12">
        <div
          class="py-7 grid gap-10 md:grid-12 grid-cols-8 max-w-370 mx-auto md:py-8"
        >
          <div class="col-end-4 col-start-1">
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="mailto:armand.thuillart@proton.me">armand.thuillart@pm.me</a
            >
          </div>

          <div
            class="flex flex-col items-start gap-2 col-start-5 col-end-8 md:col-end-9 lg:col-end-7"
          >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://x.com/armandthuillart">X</a
            >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://github.com/thuillart">GitHub</a
            >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://www.linkedin.com/in/armandthuillart/">LinkedIn</a
            >
          </div>

          <div class="max-lg:hidden col-start-7 col-end-9">
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="/writings">Writings</a
            >
          </div>

          <h1
            class="font-serif col-start-1 col-end-9 text-4xl text-balance md:text-5xl xl:col-end-5"
          >
            {description}
          </h1>

          <slot />

          <div class="col-end-9 col-start-1 lg:col-start-3">
            <div class="h-px w-8 bg-muted"></div>
          </div>

          <div class="col-end-9 md:col-end-3 col-start-1">
            <div class="text-base text-pretty">
              © {new Date().getFullYear()}
            </div>
          </div>

          <div
            class="items-start flex flex-col gap-2 col-end-9 xl:col-end-7 col-start-1 md:col-start-3"
          >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://x.com/armandthuillart">X</a
            >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://github.com/thuillart">GitHub</a
            >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://www.linkedin.com/in/armandthuillart/">LinkedIn</a
            >
            <a
              class="font-sans text-base decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
              href="https://www.youtube.com/@armandthuillart">YouTube</a
            >
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
