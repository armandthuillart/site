---
const formatter = new Intl.DateTimeFormat("en-US", {
  hour: "2-digit",
  minute: "2-digit",
  hour12: true,
  timeZone: "Europe/Paris",
  timeZoneName: "shortOffset",
});
const display = formatter.format(new Date());
---

<time class="text-accent dark:text-muted-foreground/50 text-xs font-[460]">
  {display}
</time>
