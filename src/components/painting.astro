---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  alt: string;
  url: ImageMetadata;
}

const { url, alt } = Astro.props;
---

<div
  class="relative my-8 block w-full md:left-1/2 md:my-16 md:w-screen md:max-w-6xl md:-translate-x-1/2"
>
  <div class="bg-border dark:bg-selection p-2">
    <Image
      src={url}
      alt={alt}
      class="border-border pointer-events-none aspect-video size-full border object-cover object-bottom select-none"
      width={1152}
      height={648}
    />
  </div>
</div>
