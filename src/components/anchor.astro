---
interface Props {
	class?: string;
}

const { class: className = "", ...props } = Astro.props;
---

<a
	class:list={["font-sans text-pretty text-lg decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current", className]}
	{...props}
	><slot /></a
>
