---
import "@/styles/global.css";
import image from "@/images/opengraph-image.png";

type Props = { title: string };

const { title } = Astro.props;
---

<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="generator" content={Astro.generator}>

<link
	rel="alternate"
	type="application/rss+xml"
	href={new URL('rss.xml', Astro.site)}
	title="Armand Thuillart"
>

<link rel="icon" href="/favicon.ico">
<link rel="sitemap" href="/sitemap-index.xml">
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)}>

<title>{title}</title>
<meta name="title" content={title}>
<meta name="description" content="Designer and developer.">

<meta property="og:url" content={Astro.url}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:image" content={new URL(image.src, Astro.url)}>
<meta property="og:description" content="Designer and developer.">

<meta property="twitter:url" content={Astro.url}>
<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:title" content={title}>
<meta property="twitter:image" content={new URL(image.src, Astro.url)}>
<meta property="twitter:description" content="Designer and developer.">
