---
import "@styles/global.css";
import ogImage from "@public/og-image.png";
import { Font } from "astro:assets";

interface Props {
  title: string;
}

let { title } = Astro.props;

if (Astro.url.pathname !== "/") {
  title = title + " · Armand Thuillart";
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<link
  rel="alternate"
  type="application/rss+xml"
  href={new URL("rss.xml", Astro.site)}
  title="Armand Thuillart"
/>

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content="Designer and developer." />

<meta property="og:url" content={Astro.url} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:image" content={ogImage.src} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="Armand Thuillart" />
<meta property="og:description" content="Designer and developer." />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@armandthuillart" />
<meta name="twitter:creator" content="@armandthuillart" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content="Designer and developer." />
<meta name="twitter:image" content={ogImage.src} />

<Font cssVariable="--font-die-grotesk-a" preload />
<Font cssVariable="--font-die-grotesk-b" preload />
