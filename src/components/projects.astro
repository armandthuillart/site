<div class="col-start-1 col-end-9 md:col-end-3">
  <h2 class="font-sans text-lg text-pretty">Some of my projects</h2>
</div>

<div
  class="col-start-1 col-end-9 grid grid-cols-2 gap-10 md:grid-cols-4 md:gap-12 lg:col-start-3 lg:grid-cols-6"
>
  <a
    class="group flex flex-col gap-2 focus-visible:outline-none"
    href="https://www.rosace.app"
  >
    <div
      aria-label="Rosace"
      class="group-focus-visible:text-background bg-muted group-focus-visible:bg-foreground flex aspect-square items-center justify-center group-focus-visible:outline-offset-2 focus-visible:outline-current"
    >
      <svg
        aria-hidden="true"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
        class="size-16"
        viewBox="0 0 24 24"
      >
        <use href="/sprite.svg#rosace"></use>
      </svg>
    </div>

    <p
      class="group-active:bg-foreground group-active:text-background w-fit font-sans text-base text-pretty decoration-1 underline-offset-4 not-group-hover:not-focus-visible:underline"
    >
      Rosace
    </p>
  </a>

  <a
    class="group flex flex-col gap-2 focus-visible:outline-none"
    href="https://github.com/armandthuillart/crosspost"
  >
    <div
      aria-label="Crosspost"
      class="group-focus-visible:text-background bg-muted group-focus-visible:bg-foreground flex aspect-square items-center justify-center group-focus-visible:outline-offset-2 focus-visible:outline-current"
    >
      <svg
        aria-hidden="true"
        class="size-13.5"
        fill="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <use href="/sprite.svg#crosspost"></use>
      </svg>
    </div>

    <p
      class="group-active:bg-foreground group-active:text-background w-fit font-sans text-base text-pretty decoration-1 underline-offset-4 not-group-hover:not-focus-visible:underline"
    >
      Crosspost
    </p>
  </a>

  <a
    class="group flex flex-col gap-2 focus-visible:outline-none"
    href="https://github.com/armandthuillart/remark"
  >
    <div
      aria-label="Remark"
      class="group-focus-visible:text-background bg-muted group-focus-visible:bg-foreground flex aspect-square items-center justify-center group-focus-visible:outline-offset-2 focus-visible:outline-current"
    >
      <svg
        aria-hidden="true"
        class="size-16"
        fill="currentColor"
        fill-rule="evenodd"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <use href="/sprite.svg#remark"></use>
      </svg>
    </div>

    <p
      class="group-active:bg-foreground group-active:text-background w-fit font-sans text-base text-pretty decoration-1 underline-offset-4 not-group-hover:not-focus-visible:underline"
    >
      Remark
    </p>
  </a>
</div>
