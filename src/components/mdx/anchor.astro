---
const { ...props } = Astro.props;
---

<a
  aria-label={`Link to ${props.href}`}
  class="font-sans text-pretty text-lg decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
  {...props}><slot /></a
>
