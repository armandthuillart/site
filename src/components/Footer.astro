---
import { getLangFromURL, getTranslations } from "@i18n/utils";

const lang = getLangFromURL(Astro.url);
const t = getTranslations(lang);

const quotes = Object.values(t("quotes"));
const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];

const formatter = new Intl.DateTimeFormat("en-US", {
  hour: "2-digit",
  minute: "2-digit",
  hour12: true,
  timeZone: "Europe/Paris",
  timeZoneName: "shortOffset",
});
const display = formatter.format(new Date());
---

<footer class="mt-11.5 flex flex-col">
  <p
    class="text-accent dark:text-muted-foreground/50 inline-flex text-xs font-[460]"
  >
    {randomQuote}
  </p>

  <time class="text-accent dark:text-muted-foreground/50 text-xs font-[460]">
    {display}
  </time>
</footer>
