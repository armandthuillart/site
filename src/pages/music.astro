---
export const prerender = true;

import BaseLayout from "@/layouts/base-layout.astro";
---

<BaseLayout
	headline="Replay counts have been climbing for these tracks."
	title="Music · Armand Thuillart"
>
	<div class="col-start-1 col-end-9">
		<a
			class="group/link font-sans inline-flex gap-1 items-center text-lg decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
			href="/"
			>Go back home
			<svg
				fill="none"
				class="size-4 shrink-0"
				xmlns="http://www.w3.org/2000/svg"
				stroke="currentColor"
				view-box="0 0 16 16"
				aria-hidden="true"
				stroke-width="1"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path
					class="transition-transform duration-100 group-hover/link:translate-x-1 group-focus-visible/link:translate-x-1"
					d="M6 12L10 8L6 4"
				/>
				<path
					class="opacity-0 transition-opacity duration-100 group-hover/link:opacity-100 group-focus-visible/link:opacity-100"
					d="M2 8L13 8"
				/>
			</svg></a
		>
	</div>

	<div class="col-start-1 col-end-9 md:col-start-3 xl:col-end-7">
		<p
			id="music-error"
			class="font-sans text-lg text-red-500 hidden"
			data-error
			aria-hidden="true"
		/>

		<div id="music-stats">
			<h2 class="font-serif text-xl font-medium">Top artists</h2>

			<ol
				id="music-artists"
				class="mt-4 list-none space-y-3 pl-0"
				aria-busy="true"
			>
				{Array.from({ length: 10 }).map((_, i) => (
					<li class="flex items-center gap-3">
						<span class="w-5 text-sm tabular-nums">{i + 1}</span>

						<span class="size-8 rounded-full bg-foreground/10 animate-pulse" aria-hidden="true" />

						<span class="inline-block h-5 w-32 rounded bg-foreground/10 animate-pulse" aria-hidden="true" />
					</li>
				))}
			</ol>

			<h2 class="font-serif text-xl font-medium mt-14">Top tracks</h2>
			<ol
				id="music-tracks"
				class="mt-4 list-none space-y-3 pl-0"
				aria-busy="true"
			>
				{Array.from({ length: 10 }).map((_, i) => (
					<li class="flex items-center gap-3">
						<span class="w-5 text-sm tabular-nums">{i + 1}</span>
						
						<span class="size-8 rounded bg-foreground/10 animate-pulse" aria-hidden="true" />

						<div class="flex flex-col gap-0.5">
							<span class="inline-block h-4 w-36 rounded bg-foreground/10 animate-pulse" aria-hidden="true" />
							<span class="inline-block h-3 w-24 rounded bg-foreground/10 animate-pulse" aria-hidden="true" />
						</div>
					</li>
				))}
			</ol>

			<p id="music-footer" class="font-sans text-base mt-10">
				<span
					class="inline-block h-4 w-56 rounded bg-foreground/10 animate-pulse"
					aria-hidden="true"
				/>
			</p>
		</div>
	</div>

	<script>
	import { tryCatch } from "@/lib/utils.ts";

	interface Artist {
		artworkUrl?: string;
		count: number;
		name: string;
	}

	interface Track {
		artist: string;
		artworkUrl?: string;
		count: number;
		name: string;
		url?: string;
	}

	function el(
		tag: string,
		className: string,
		children?: (Node | string)[],
	): HTMLElement {
		const node = document.createElement(tag);
		if (className) {
			node.className = className;
		}
		if (children) {
			node.append(...children);
		}
		return node;
	}

	function rankSpan(i: number): HTMLElement {
		return el("span", "w-5 text-sm text-neutral-500 tabular-nums", [
			String(i + 1),
		]);
	}

	const ARTWORK_SIZE = 32;

	function artworkImg(
		alt: string,
		src: string,
		rounded: string,
	): HTMLImageElement {
		const img = document.createElement("img");
		img.alt = alt;
		img.loading = "lazy";
		img.width = ARTWORK_SIZE;
		img.height = ARTWORK_SIZE;
		img.decoding = "async";
		img.className = `size-8 ${rounded} object-cover`;
		img.src = src;
		return img;
	}

	function artworkPlaceholder(rounded: string): HTMLElement {
		const span = el("span", `size-8 ${rounded} bg-foreground/10 flex shrink-0`);
		span.setAttribute("aria-hidden", "true");
		return span;
	}

	function renderArtist(a: Artist, i: number): HTMLElement {
		let artwork: HTMLElement;
		if (a.artworkUrl) {
			artwork = artworkImg(a.name, a.artworkUrl, "rounded-full");
		} else {
			artwork = artworkPlaceholder("rounded-full");
		}

		return el("li", "flex items-center gap-3", [
			rankSpan(i),
			artwork,
			el("span", "font-medium", [a.name]),
		]);
	}

	function renderTrack(t: Track, i: number): HTMLElement {
		let artwork: HTMLElement;
		if (t.artworkUrl) {
			artwork = artworkImg(t.name, t.artworkUrl, "rounded");
		} else {
			artwork = artworkPlaceholder("rounded");
		}

		let title: HTMLElement;
		if (t.url) {
			title = el(
				"a",
				"font-medium decoration-neutral-500 decoration-1 underline-offset-[2.5px] hover:underline",
				[t.name],
			);
			title.setAttribute("href", t.url);
			title.setAttribute("target", "_blank");
			title.setAttribute("rel", "noopener noreferrer");
		} else {
			title = el("span", "font-medium", [t.name]);
		}

		return el("li", "flex items-center gap-3", [
			rankSpan(i),
			artwork,
			el("div", "flex flex-col", [
				title,
				el("span", "text-sm text-neutral-600 dark:text-neutral-400", [
					t.artist,
				]),
			]),
		]);
	}

	(async () => {
		const artistsEl = document.getElementById("music-artists");
		const tracksEl = document.getElementById("music-tracks");
		const footerEl = document.getElementById("music-footer");
		const errorEl = document.getElementById("music-error");

		if (!(artistsEl && tracksEl && footerEl && errorEl)) {
			return;
		}

		const fetchStats = async () => {
			const res = await fetch("/api/music-stats");
			const data = await res.json();

			if (!res.ok) {
				throw new Error(data.error ?? "Something went wrong.");
			}

			return data;
		};

		const result = await tryCatch(fetchStats());

		if (result.error) {
			errorEl.textContent = result.error.message;
			errorEl.classList.remove("hidden");
			errorEl.removeAttribute("aria-hidden");
			document.getElementById("music-stats")?.setAttribute("hidden", "");
			return;
		}

		const { topArtists, topTracks, totalTracks } = result.data;

		artistsEl.setAttribute("aria-busy", "false");
		artistsEl.replaceChildren(
			...topArtists.map((a: Artist, i: number) => renderArtist(a, i)),
		);

		tracksEl.setAttribute("aria-busy", "false");
		tracksEl.replaceChildren(
			...topTracks.map((t: Track, i: number) => renderTrack(t, i)),
		);

		footerEl.textContent = `Based on the last ${totalTracks} tracks played.`;
	})();
	</script>
</BaseLayout>
