---
import BaseLayout from "@/layouts/base-layout.astro";
import { SITE_DESCRIPTION } from "@/constants";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).filter(
	(post) => post.id !== "index",
);
---

<BaseLayout description={SITE_DESCRIPTION} title="Writings · Armand Thuillart">
	<div class="px-6 md:px-12">
		<div
			class="py-7 grid gap-10 md:grid-12 grid-cols-8 max-w-370 mx-auto md:py-8"
		>
			<div class="col-end-4 col-start-1">
				<h1 class="text-4xl font-bold">Writings</h1>
			</div>
		</div>
	</div>
</BaseLayout>
