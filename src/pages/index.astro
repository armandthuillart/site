---
import BaseLayout from "@/layouts/base-layout.astro";
---

<BaseLayout
	headline="Designer and developer living in Paris, France."
	title="Armand Thuillart"
>
	<div class="col-start-1 col-end-9">
		<a
			class="group/link font-sans inline-flex gap-1 items-center text-lg decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
			href="/biography"
			>Biography
			<svg
				fill="none"
				class="size-4 shrink-0"
				xmlns="http://www.w3.org/2000/svg"
				stroke="currentColor"
				view-box="0 0 16 16"
				aria-hidden="true"
				stroke-width="1"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path
					class="transition-transform duration-100 group-hover/link:translate-x-1 group-focus-visible/link:translate-x-1"
					d="M6 12L10 8L6 4"
				/>
				<path
					class="opacity-0 transition-opacity duration-100 group-hover/link:opacity-100 group-focus-visible/link:opacity-100"
					d="M2 8L13 8"
				/>
			</svg></a
		>
	</div>

	<div
		class="flex flex-col gap-4 col-start-1 col-end-9 md:col-start-3 xl:col-end-7"
	>
		<p class="font-sans text-lg text-pretty">
			Currently building two companies. Majoring in business administration
			aside. I’ve been coding for three years and building for the second half.
		</p>

		<p class="font-sans text-lg text-pretty">
			I wear a lot of hats. I'm a student, designer, and developer. All together
			makes me an entrepreneur who builds things.
		</p>

		<p class="font-sans text-lg text-pretty">
			I also like art, music, and reading. My wallpaper is a
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="/paintings"
				>painting</a
			>. I make
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="/music"
				id="music-link"
				>music</a
			>
			when not listening to it, and read
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="/readings"
				>books</a
			>
			of various kinds.
		</p>

		<p class="font-sans text-lg text-pretty">
			You can read my
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="/writings"
				>writing</a
			>
			or
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="https://github.com/thuillart"
				>code</a
			>, or follow me
			<span
				id="follow-online"
				class="cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				role="button"
				tabindex="0"
			>
				<span
					id="follow-online-label"
					class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
					>online</span
				>
				<span id="follow-online-links" class="hidden" aria-hidden="true">
					on
					<a
						class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
						href="https://x.com/armandthuillart"
						rel="noopener noreferrer"
						target="_blank"
						>X</a
					>
					and
					<a
						class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
						href="https://linkedin.com/in/armandthuillart"
						rel="noopener noreferrer"
						target="_blank"
						>LinkedIn</a
					>
				</span>
			</span>. I also make
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="https://youtube.com/@armandthuillart"
				rel="noopener noreferrer"
				target="_blank"
				>videos</a
			>, advise companies, and do angel investing.
			<a
				class="decoration-1 underline-offset-4 not-hover:not-focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current active:bg-foreground active:text-background"
				href="mailto:armand.thuillart@proton.me"
				>Reach</a
			>
			out if interested.
		</p>
	</div>

	<div class="col-end-9 col-start-1 lg:col-start-3">
		<div class="h-px w-8 bg-muted" />
	</div>

	<div class="col-start-1 col-end-9 md:col-end-3">
		<h2 class="font-sans text-lg text-pretty">Companies</h2>
	</div>

	<div
		class="grid gap-10 md:gap-12 col-end-9 col-start-1 lg:col-start-3 grid-cols-2 md:grid-cols-4 lg:grid-cols-6"
	>
		<div class="flex flex-col gap-2">
			<a
				class="group/card aspect-square flex items-center justify-center bg-muted hover:bg-yellow focus-visible:bg-yellow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
				href="https://neap.app"
				aria-label="Neap"
			>
				<svg
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
					width="68"
					height="32"
					view-box="0 0 68 32"
					aria-hidden="true"
				>
					<path
						d="M0 23.5164C11.7242 23.5164 21.1035 12.9629 18.4528 0H27.0844L36.2938 31.9661H27.4582L23.6861 18.4942C19.4723 25.6543 11.4183 31.8303 0 31.9661V23.5164Z"
						class="group-hover/card:fill-black/90 group-focus-visible/card:fill-black/90"
					/>
					<path
						d="M68 8.48356C56.2758 8.48356 46.8965 19.0371 49.5472 32H40.9156L31.7062 0.033928H40.5418L44.3139 13.5058C48.5277 6.3457 56.5817 0.169671 68 0.033928V8.48356Z"
						class="group-hover/card:fill-black/90 group-focus-visible/card:fill-black/90"
					/>
				</svg>
			</a>

			<p class="font-sans text-base text-pretty">Neap</p>
		</div>

		<div class="flex flex-col gap-2">
			<a
				class="group/card aspect-square flex items-center justify-center bg-muted hover:bg-blue focus-visible:bg-blue focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
				href="https://dome.family"
				aria-label="Dome"
			>
				<svg
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
					width="67"
					height="32"
					view-box="0 0 67 32"
					aria-hidden="true"
				>
					<path
						d="M67 32C67 27.7977 66.1335 23.6365 64.45 19.7541C62.7664 15.8717 60.2988 12.3441 57.1881 9.37258C54.0773 6.40111 50.3843 4.044 46.3199 2.43585C42.2555 0.827704 37.8993 -1.83688e-07 33.5 0C29.1007 1.83688e-07 24.7445 0.827705 20.6801 2.43586C16.6157 4.04401 12.9227 6.40111 9.81192 9.37258C6.70116 12.3441 4.23357 15.8717 2.55003 19.7541C0.866502 23.6365 -3.84597e-07 27.7977 0 32L67 32Z"
						class="group-hover/card:fill-white group-focus-visible/card:fill-white"
					/>
				</svg>
			</a>

			<p class="font-sans text-base text-pretty">Dome</p>
		</div>
	</div>

	<div class="col-end-9 col-start-1 lg:col-start-3">
		<div class="h-px w-8 bg-muted" />
	</div>

	<div class="col-start-1 col-end-9 md:col-end-3">
		<h2 class="font-sans text-lg text-pretty">Academic background</h2>
	</div>

	<div class="col-start-1 col-end-9 md:col-start-3 xl:col-end-7">
		<div class="flex flex-col">
			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2025-2026</span>

				<span class="font-sans text-lg text-pretty">Paris (France)</span>

				<span class="font-sans text-lg text-pretty">Master 2</span>
			</div>

			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2024-2025 </span>

				<span class="font-sans text-lg text-pretty">Boston (USA)</span>

				<span class="font-sans text-lg text-pretty">Exchange at UMB</span>
			</div>

			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2024-2025</span>

				<span class="font-sans text-lg text-pretty">Caen (France)</span>

				<span class="font-sans text-lg text-pretty">Master 1</span>
			</div>

			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2023-2024</span>

				<span class="font-sans text-lg text-pretty">Dublin (Ireland)</span>

				<span class="font-sans text-lg text-pretty">Exchange at TUD</span>
			</div>

			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2023-2024</span>

				<span class="font-sans text-lg text-pretty">Santiago (Chile)</span>

				<span class="font-sans text-lg text-pretty">Exchange at UAI</span>
			</div>

			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2022-2023</span>

				<span class="font-sans text-lg text-pretty">Oxford (UK)</span>

				<span class="font-sans text-lg text-pretty">Undergraduate 2</span>
			</div>

			<div
				class="first:border-t border-border border-b py-3 grid gap-10 lg:gap-12 grid-cols-3"
			>
				<span class="font-sans text-lg text-pretty">2021-2022</span>

				<span class="font-sans text-lg text-pretty">Paris (France)</span>

				<span class="font-sans text-lg text-pretty">Undergraduate 1</span>
			</div>
		</div>
	</div>

	<div class="col-end-9 col-start-1 lg:col-start-3">
		<div class="h-px w-8 bg-muted" />
	</div>

	<div class="col-start-1 col-end-9 md:col-end-3">
		<h2 class="font-sans text-lg text-pretty">In case you are curious</h2>
	</div>

	<div class="col-start-1 col-end-9 md:col-start-3 xl:col-end-7">
		<details class="group/accordion border-t border-border last:border-b">
			<summary
				class="flex font-sans w-full cursor-pointer list-none justify-between gap-6 py-3 text-lg text-pretty [&::-webkit-details-marker]:hidden focus-visible:outline-current"
			>
				<h3>Are you open to work?</h3>

				<svg
					fill="currentColor"
					class="my-auto group-open/accordion:hidden size-5"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M8 2.75C8 2.47386 7.77614 2.25 7.5 2.25C7.22386 2.25 7 2.47386 7 2.75V7H2.75C2.47386 7 2.25 7.22386 2.25 7.5C2.25 7.77614 2.47386 8 2.75 8H7V12.25C7 12.5261 7.22386 12.75 7.5 12.75C7.77614 12.75 8 12.5261 8 12.25V8H12.25C12.5261 8 12.75 7.77614 12.75 7.5C12.75 7.22386 12.5261 7 12.25 7H8V2.75Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>

				<svg
					class="my-auto  size-5 not-group-open/accordion:hidden"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M2.25 7.5C2.25 7.22386 2.47386 7 2.75 7H12.25C12.5261 7 12.75 7.22386 12.75 7.5C12.75 7.77614 12.5261 8 12.25 8H2.75C2.47386 8 2.25 7.77614 2.25 7.5Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>
			</summary>

			<p class="font-sans mt-1 pb-3 text-lg text-pretty">
				I’m always all ears for new opportunities. Don’t hesistate to reach out!
			</p>
		</details>

		<details class="group/accordion border-t border-border last:border-b">
			<summary
				class="flex font-sans w-full cursor-pointer list-none justify-between gap-6 py-3 text-lg text-pretty [&::-webkit-details-marker]:hidden focus-visible:outline-current"
			>
				<h3>What are you best at?</h3>

				<svg
					fill="currentColor"
					class="my-auto group-open/accordion:hidden size-5"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M8 2.75C8 2.47386 7.77614 2.25 7.5 2.25C7.22386 2.25 7 2.47386 7 2.75V7H2.75C2.47386 7 2.25 7.22386 2.25 7.5C2.25 7.77614 2.47386 8 2.75 8H7V12.25C7 12.5261 7.22386 12.75 7.5 12.75C7.77614 12.75 8 12.5261 8 12.25V8H12.25C12.5261 8 12.75 7.77614 12.75 7.5C12.75 7.22386 12.5261 7 12.25 7H8V2.75Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>

				<svg
					class="my-auto  size-5 not-group-open/accordion:hidden"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M2.25 7.5C2.25 7.22386 2.47386 7 2.75 7H12.25C12.5261 7 12.75 7.22386 12.75 7.5C12.75 7.77614 12.5261 8 12.25 8H2.75C2.47386 8 2.25 7.77614 2.25 7.5Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>
			</summary>

			<p class="font-sans mt-1 pb-3 text-lg text-pretty">
				Learning by doing. Neap taught me software, Dome taught me hardware, and
				I never go to bed without learning something new.
			</p>
		</details>

		<details class="group/accordion border-t border-border last:border-b">
			<summary
				class="flex font-sans w-full cursor-pointer list-none justify-between gap-6 py-3 text-lg text-pretty [&::-webkit-details-marker]:hidden focus-visible:outline-current"
			>
				<h3>Remote or on-site?</h3>

				<svg
					fill="currentColor"
					class="my-auto group-open/accordion:hidden size-5"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M8 2.75C8 2.47386 7.77614 2.25 7.5 2.25C7.22386 2.25 7 2.47386 7 2.75V7H2.75C2.47386 7 2.25 7.22386 2.25 7.5C2.25 7.77614 2.47386 8 2.75 8H7V12.25C7 12.5261 7.22386 12.75 7.5 12.75C7.77614 12.75 8 12.5261 8 12.25V8H12.25C12.5261 8 12.75 7.77614 12.75 7.5C12.75 7.22386 12.5261 7 12.25 7H8V2.75Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>

				<svg
					class="my-auto  size-5 not-group-open/accordion:hidden"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M2.25 7.5C2.25 7.22386 2.47386 7 2.75 7H12.25C12.5261 7 12.75 7.22386 12.75 7.5C12.75 7.77614 12.5261 8 12.25 8H2.75C2.47386 8 2.25 7.77614 2.25 7.5Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>
			</summary>

			<p class="font-sans mt-1 pb-3 text-lg text-pretty">
				I’m fine with both. For on-site positions, I’d consider Paris, London,
				New York, or San Francisco.
			</p>
		</details>

		<details class="group/accordion border-t border-border last:border-b">
			<summary
				class="flex font-sans w-full cursor-pointer list-none justify-between gap-6 py-3 text-lg text-pretty [&::-webkit-details-marker]:hidden focus-visible:outline-current"
			>
				<h3>How to get in touch?</h3>

				<svg
					fill="currentColor"
					class="my-auto group-open/accordion:hidden size-5"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M8 2.75C8 2.47386 7.77614 2.25 7.5 2.25C7.22386 2.25 7 2.47386 7 2.75V7H2.75C2.47386 7 2.25 7.22386 2.25 7.5C2.25 7.77614 2.47386 8 2.75 8H7V12.25C7 12.5261 7.22386 12.75 7.5 12.75C7.77614 12.75 8 12.5261 8 12.25V8H12.25C12.5261 8 12.75 7.77614 12.75 7.5C12.75 7.22386 12.5261 7 12.25 7H8V2.75Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>

				<svg
					class="my-auto  size-5 not-group-open/accordion:hidden"
					view-box="0 0 15 15"
					aria-hidden="true"
				>
					<path
						d="M2.25 7.5C2.25 7.22386 2.47386 7 2.75 7H12.25C12.5261 7 12.75 7.22386 12.75 7.5C12.75 7.77614 12.5261 8 12.25 8H2.75C2.47386 8 2.25 7.77614 2.25 7.5Z"
						fill="currentColor"
						fill-rule="evenodd"
						clip-rule="evenodd"
					/>
				</svg>
			</summary>

			<p class="font-sans mt-1 pb-3 text-lg text-pretty">
				Email is best. I check it daily. X or LinkedIn are also fine.
			</p>
		</details>
	</div>

	<script>
	const label = document.getElementById("follow-online-label");
	const links = document.getElementById("follow-online-links");
	const trigger = document.getElementById("follow-online");

	function showLinks() {
		if (label) {
			label.classList.add("hidden");
			label.setAttribute("aria-hidden", "true");
		}

		if (links) {
			links.classList.remove("hidden");
			links.removeAttribute("aria-hidden");
		}

		if (trigger) {
			trigger.removeAttribute("role");
			trigger.dataset.expanded = "true";
			trigger.removeAttribute("tabindex");
			trigger.removeEventListener("click", showLinks);
			trigger.removeEventListener("keydown", handleKeyDown);
		}
	}

	function handleKeyDown(event: KeyboardEvent) {
		if (event.key === "Enter" || event.key === " ") {
			event.preventDefault();
			showLinks();
		}
	}

	if (trigger) {
		trigger.addEventListener("click", showLinks);
		trigger.addEventListener("keydown", handleKeyDown);
	}

	const link = document.getElementById("music-link");

	if (link) {
		link.addEventListener("mouseenter", () => fetch("/api/music-stats"), {
			once: true,
		});
		link.addEventListener("focus", () => fetch("/api/music-stats"), {
			once: true,
		});
	}
	</script>
</BaseLayout>
