---
import BaseLayout from "@layouts/base-layout.astro";

const startedCodingOn = new Date("2023-06-13");
const startedBuildingOn = new Date("2025-04-21");

function getCalendarDuration(from: Date, to: Date) {
  const start = new Date(from);
  const end = new Date(to);

  let years = end.getFullYear() - start.getFullYear();
  let months = end.getMonth() - start.getMonth();
  let days = end.getDate() - start.getDate();

  if (days < 0) {
    months -= 1;
    const daysInPreviousMonth = new Date(
      end.getFullYear(),
      end.getMonth(),
      0,
    ).getDate();
    days += daysInPreviousMonth;
  }

  if (months < 0) {
    years -= 1;
    months += 12;
  }

  return { days, months, years };
}

function getRoundedMonths(from: Date, to: Date) {
  const { years, months, days } = getCalendarDuration(from, to);
  const roundedDaysToMonth = days >= 15 ? 1 : 0;

  return years * 12 + months + roundedDaysToMonth;
}

function getRoundedYears(from: Date, to: Date) {
  const roundedMonths = getRoundedMonths(from, to);

  return Math.round(roundedMonths / 12);
}

function toWord(value: number) {
  const words = [
    "zero",
    "one",
    "two",
    "three",
    "four",
    "five",
    "six",
    "seven",
    "eight",
    "nine",
    "ten",
  ];

  if (value >= 0 && value <= 10) {
    return words[value];
  }

  return String(value);
}

function formatYearsInWords(value: number) {
  const word = toWord(value);

  return `${word} year${value === 1 ? "" : "s"}`;
}

function formatPastYears(from: Date, to: Date) {
  const roundedMonths = getRoundedMonths(from, to);
  const roundedHalfYears = Math.round(roundedMonths / 6) / 2;

  if (roundedHalfYears <= 0.5) {
    return "half a year";
  }

  if (Number.isInteger(roundedHalfYears)) {
    const fullYears = roundedHalfYears;
    if (fullYears === 1) {
      return "year";
    }
    return `${toWord(fullYears)} years`;
  }

  const fullYears = Math.floor(roundedHalfYears);
  if (fullYears === 1) {
    return "year and a half";
  }

  return `${toWord(fullYears)} and a half years`;
}

const now = new Date();

const haveBeenCodingFor = formatYearsInWords(
  getRoundedYears(startedCodingOn, now),
);
const haveBeenBuildingFor = formatPastYears(startedBuildingOn, now);
